# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option A: connection string (takes priority if set)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/datapulse

# Option B: individual fields (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapulse
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
